# ============================================
# TWILIO LIVE SMS CONFIGURATION
# ============================================
# Server-side only. Used by /api/marketing-subscribe (confirmation SMS),
# /api/marketing-send (broadcast SMS), /api/marketing-optout (STOP webhook
# signature validation). Without these set, SMS paths short-circuit cleanly
# back to logged warning + sender record written with status=failed.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+15551234567

# ============================================
# BROADCAST ADMIN TOKEN (marketing-send only)
# ============================================
# Server-side token that /api/marketing-send requires via Bearer auth.
# Operator mirrors this to /api/admin/verify response.data.token, OR sets
# ADMIN_SESSION_TOKEN=same_value so the admin dashboard session reuses it.
ADMIN_BROADCAST_TOKEN=rotate_me_per_environment
ADMIN_SESSION_TOKEN=rotate_me_per_environment
