# ============================================
# PAYPAL LIVE PAYMENT CONFIGURATION
# ============================================
# The VITE_ value loads the browser SDK; server values are used by /api/paypal-order
# and /api/complete-order to create, capture, and verify paid PayPal orders.
# PayPal Pay Later / BNPL uses these same credentials. The browser SDK enables
# paylater funding, but PayPal decides whether to show it per buyer/order.
VITE_PAYPAL_CLIENT_ID=YOUR_LIVE_PAYPAL_CLIENT_ID_HERE
PAYPAL_CLIENT_ID=YOUR_LIVE_PAYPAL_CLIENT_ID_HERE
PAYPAL_CLIENT_SECRET=YOUR_LIVE_PAYPAL_CLIENT_SECRET_HERE
PAYPAL_ENV=live

